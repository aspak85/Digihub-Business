# Copy this file to .env for LOCAL testing only (netlify dev).
# Never commit the real .env file — it is already listed in .gitignore.
# For the LIVE site, set these same two values in:
# Netlify dashboard → Site settings → Environment variables
# (do NOT put real secrets in any file that gets pushed to GitHub)

RAZORPAY_KEY_ID=your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here
